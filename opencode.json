{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.tfstate*": "deny"
    },
    "bash": {
      "*": "ask"
    }
  },
  "provider": {
  },
  "mcp": {
    "bodega": {
      "type": "local",
      "command": ["bodega", "mcp", "stdio"],
      "enabled": true
    }
  }
}
